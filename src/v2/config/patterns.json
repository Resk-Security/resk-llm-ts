      { "name": "embedded_link", "pattern": "(?:embedded|internal|hidden)\\s+(?:link|url|reference|resource)\\s*:?\\s*https?://", "description": "Embedded links in document content" },
      { "name": "macro_reference", "pattern": "\\b(?:macro|script|automate|vba|applescript)\\s+(?:in|with|using)\\s+(?:the\\s+)?(?:document|file|sheet|presentation)", "description": "Reference to embedded macros in documents" }
