      { "name": "metadata_author_instruction", "pattern": "(?:author|title|subject|comment|description)\\s*(?:field|entry|value)?\\s*:.*?(?:ignore|bypass|override|system|instruction|prompt)", "description": "Metadata fields containing instructions" }
